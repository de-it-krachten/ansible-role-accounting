---

# Generic
generic:
  role: ansible-role-accounting
  role_short: accounting
  role_description: |
    Setup process accounting
  collections: []

# Supported platforms
platforms:
  sles15:
    supported: true
    ci: false
  sles16:
    supported: true
    ci: false
  opensuse15:
    supported: true
    ci: true
  opensuse16:
    supported: true
    ci: true

# Molecule
molecule:
  requirements:
    roles_extra: []
